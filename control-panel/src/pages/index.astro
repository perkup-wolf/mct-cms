---
import Base from '../layouts/Base.astro';
import { getClients } from '../lib/db';

const db = Astro.locals.runtime.env.DB;
const clients = await getClients(db);
---
<Base title="Clients">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <h1>Client Instances</h1>
    <a href="/clients/new" class="btn btn-primary">+ New Client</a>
  </div>

  {clients.length === 0 ? (
    <p style="color:#6b7280">No clients yet. Click "New Client" to provision the first one.</p>
  ) : (
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Domain</th>
          <th>Admin Email</th>
          <th>Status</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {clients.map(client => (
          <tr>
            <td><strong>{client.name}</strong></td>
            <td><a href={`https://cms.${client.domain}`} target="_blank" rel="noopener">cms.{client.domain}</a></td>
            <td>{client.admin_email}</td>
            <td><span class={`badge badge-${client.status}`}>{client.status}</span></td>
            <td style="color:#6b7280">{new Date(client.created_at).toLocaleDateString()}</td>
            <td><a href={`/clients/${client.id}`} class="btn btn-primary" style="padding:0.25rem 0.75rem">View</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Base>
