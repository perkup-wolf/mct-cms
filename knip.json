{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		"packages/core": {
			"entry": ["src/astro/**/*.ts", "src/db/*.ts", "src/storage/*.ts"],
			"ignoreDependencies": [
				"cloudflare",
				"@aws-sdk/client-s3",
				"@aws-sdk/s3-request-presigner",
				"@vitest/coverage-v8"
			]
		},
		"packages/auth": {
			"ignoreDependencies": ["cloudflare", "kysely"]
		},
		"packages/admin": {},
		"packages/gutenberg-to-portable-text": {},
		"packages/sandbox-cloudflare": {
			"ignoreDependencies": ["cloudflare"]
		}
	},
	"ignore": ["**/dist/**", "**/*.d.ts"],
	"ignoreDependencies": ["@changesets/cli"]
}
